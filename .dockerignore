# flyctl launch added from .gitignore
# Secrets — CONF-1: never commit actual environment variables
**/.env
**/.env.local
**/.env.*.local

# Python
**/__pycache__
**/*.py[cod]
**/*.pyo
**/*.pyd
**/.Python
**/*.egg-info
**/dist
**/build
**/.eggs

# Virtual environments
**/venv
**/.venv
**/env
**/ENV

# Logs — LOG-1: log files stay on the server, not in the repo
**/*.log
**/logs

# IDE
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/.DS_Store

# pytest / coverage
**/.pytest_cache
**/.coverage
**/htmlcov
fly.toml
